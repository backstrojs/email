---
import type { StyleObject } from '../utils/style.js';
import { styleToString } from '../utils/style.js';

/**
 * Row – horizontal row of columns rendered as a `<table>`.
 *
 * Place one or more `<Column>` components inside `<Row>` to create
 * multi-column layouts that are compatible with legacy email clients.
 *
 * @example
 * ```astro
 * ---
 * import { Row, Column } from '@backstro/email';
 * ---
 * <Row>
 *   <Column>Left</Column>
 *   <Column>Right</Column>
 * </Row>
 * ```
 */
interface Props {
  style?: StyleObject;
  [key: string]: unknown;
}

const { style, ...rest } = Astro.props;
const tableStyle = style ? styleToString(style) : undefined;
---

<table
  align="center"
  width="100%"
  border={0}
  cellpadding="0"
  cellspacing="0"
  role="presentation"
  style={tableStyle}
  {...rest}
>
  <tbody style="width: 100%">
    <tr style="width: 100%">
      <slot />
    </tr>
  </tbody>
</table>
