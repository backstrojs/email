---
import type { StyleObject } from '../utils/style.js';
import { styleToString } from '../utils/style.js';

/**
 * Img – an image element with email-safe rendering defaults.
 *
 * Sets `display: block`, `outline: none`, `border: none`, and
 * `text-decoration: none` to avoid unwanted spacing and link borders
 * in Outlook and other legacy clients.
 *
 * @example
 * ```astro
 * ---
 * import { Img } from '@backstro/email';
 * ---
 * <Img src="https://example.com/logo.png" alt="Logo" width={200} height={50} />
 * ```
 */
interface Props {
  src?: string;
  alt?: string;
  width?: number | string;
  height?: number | string;
  style?: StyleObject;
  [key: string]: unknown;
}

const { src, alt = '', width, height, style, ...rest } = Astro.props;

const imgStyle = styleToString({
  display: 'block',
  outline: 'none',
  border: 'none',
  textDecoration: 'none',
  ...style,
});
---

<img
  src={src}
  alt={alt}
  width={width}
  height={height}
  style={imgStyle}
  {...rest}
/>
