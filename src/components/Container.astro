---
import type { StyleObject } from '../utils/style.js';
import { styleToString } from '../utils/style.js';

/**
 * Container – horizontally-centred layout wrapper rendered as a `<table>`.
 *
 * Use this as the outermost structural element inside `<Body>`. It sets a
 * `maxWidth` of `600 px` (37.5 em) by default—the safest width for email
 * clients—while forwarding any additional attributes.
 *
 * @example
 * ```astro
 * ---
 * import { Container } from '@backstro/email';
 * ---
 * <Container style={{ maxWidth: '600px' }}>
 *   <slot />
 * </Container>
 * ```
 */
interface Props {
  style?: StyleObject;
  [key: string]: unknown;
}

const { style, ...rest } = Astro.props;

const tableStyle = styleToString({ maxWidth: '560px', ...style });
---

<table
  align="center"
  width="100%"
  border={0}
  cellpadding="0"
  cellspacing="0"
  role="presentation"
  style={tableStyle}
  {...rest}
>
  <tbody>
    <tr style="width: 100%">
      <td>
        <slot />
      </td>
    </tr>
  </tbody>
</table>
